---
// src/components/global/Header.astro
---

<header class="fixed top-0 w-full z-50 bg-brand-light/80 backdrop-blur-md border-b border-gray-200/50">
  <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
    
    <a href="/" class="font-display font-bold text-2xl tracking-tighter text-brand-dark transition-opacity hover:opacity-80">
      Firma<span class="text-brand-signal">.</span>
    </a>

    <nav class="hidden md:flex gap-8 font-medium text-sm">
      <a href="/" class="hover:text-brand-signal transition-colors">Strona Główna</a>
      <a href="/o-nas" class="hover:text-brand-signal transition-colors">O nas</a>
      <a href="/realizacje" class="hover:text-brand-signal transition-colors">Realizacje</a>
      <a href="/blog" class="hover:text-brand-signal transition-colors">Blog</a>
    </nav>

    <a href="/kontakt" class="hidden md:inline-flex bg-brand-dark text-brand-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-brand-signal transition-colors duration-300">
      Darmowa Wycena
    </a>
    
    <button class="md:hidden p-2 text-brand-dark cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>

  </div>
</header>