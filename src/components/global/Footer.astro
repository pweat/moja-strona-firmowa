---
// src/components/global/Footer.astro

// Pobieramy aktualny rok, aby stopka zawsze była aktualna
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-dark text-brand-light py-8 border-t border-gray-800 mt-auto">
  <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="font-display font-bold text-xl">
      Firma<span class="text-brand-signal">.</span>
    </p>
    <p class="text-sm text-gray-400">
      &copy; {currentYear} Wszelkie prawa zastrzeżone.
    </p>
  </div>
</footer>