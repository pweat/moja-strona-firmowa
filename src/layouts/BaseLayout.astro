---
// src/layouts/BaseLayout.astro
import '../styles/global.css';

// 1. Importujemy nasze nowe komponenty
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';

const { title = "Moja Firma", description = "Nowoczesna strona internetowa" } = Astro.props;
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-brand-light text-brand-dark font-sans antialiased min-h-screen flex flex-col">
    
    <Header />

    <div class="flex-grow pt-20">
      <slot />
    </div>

    <Footer />
    
  </body>
</html>