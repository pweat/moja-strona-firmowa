---
// src/pages/blog/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchDatoCMS } from '../../lib/datocms';
import { marked } from 'marked';

interface Artykul {
  tytu: string;
  slug: string;
  zajawka: string;
  tre: string;
  zdjCieGWne: {
    url: string;
    alt: string;
  };
}

export async function getStaticPaths() {
  const query = `
    {
      allArtykuls(first: 100) {
        tytu
        slug
        zajawka
        tre
        zdjCieGWne {
          url
          alt
        }
      }
    }
  `;
  
  const data = await fetchDatoCMS(query);
  const artykuly: Artykul[] = data.allArtykuls;

  return artykuly.map((artykul) => ({
    params: { slug: artykul.slug },
    props: { artykul },
  }));
}

const { artykul } = Astro.props;

// Dynamiczne obliczanie czasu czytania
const pelnyTekst = `${artykul.zajawka} ${artykul.tre}`;
const liczbaSlow = pelnyTekst.trim().split(/\s+/).length;
const czasCzytania = Math.max(1, Math.ceil(liczbaSlow / 200));

// Tłumaczymy Markdown na HTML
const treHtml = marked.parse(artykul.tre, { breaks: true, gfm: true });

// --- LOGIKA SEO DLA TEJ PODSTRONY ---
// Wykorzystujemy "Zajawkę" jako opis do Google (ucinamy do ok. 150 znaków w razie gdyby była bardzo długa)
const seoDescription = artykul.zajawka.replace(/\n/g, ' ').slice(0, 150) + (artykul.zajawka.length > 150 ? '...' : '');

// Pobieramy zdjęcie główne i prosimy serwer DatoCMS o wykadrowanie go do idealnych proporcji Facebooka/Google
const seoImage = `${artykul.zdjCieGWne.url}?w=1200&h=630&fit=crop&q=80`;
---

<BaseLayout 
  title={`${artykul.tytu} | Baza Wiedzy Wierttrans`}
  description={seoDescription}
  image={seoImage}
>
  <main class="relative overflow-hidden bg-brand-light min-h-screen pb-24">
    
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#8080801a_1px,transparent_1px),linear-gradient(to_bottom,#8080801a_1px,transparent_1px)] bg-[length:24px_24px] pointer-events-none z-0"></div>
    <div class="absolute left-[50%] top-[40vh] -translate-x-1/2 z-0 h-125 w-[800px] rounded-full bg-brand-signal opacity-[0.08] blur-[100px] mix-blend-multiply pointer-events-none"></div>
    <div class="absolute right-[-10%] top-[60vh] z-0 h-100 w-100 rounded-full bg-blue-500 opacity-[0.06] blur-[120px] mix-blend-multiply pointer-events-none"></div>

    <div class="fixed top-28 left-4 md:left-12 z-50 reveal hidden md:block">
      <a href="/blog" class="inline-flex items-center justify-center px-6 py-3 bg-white/80 backdrop-blur-md border border-white text-brand-dark font-bold rounded-2xl shadow-lg shadow-gray-200/50 hover:bg-brand-dark hover:text-white transition-all duration-300 group">
        <svg class="w-5 h-5 mr-2 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        Wróć do bazy wiedzy
      </a>
    </div>

    <div class="md:hidden pt-28 px-4 relative z-20 reveal">
      <a href="/blog" class="inline-flex items-center text-brand-dark font-bold hover:text-brand-signal transition-colors">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        Wróć do bazy wiedzy
      </a>
    </div>

    <div class="pt-8 md:pt-12 max-w-7xl mx-auto px-4 relative z-10">
      <div class="relative w-full h-[40vh] md:h-[60vh] rounded-[3rem] overflow-hidden shadow-2xl reveal bg-gray-900">
        <img 
          src={`${artykul.zdjCieGWne.url}?auto=format&w=1920&q=80`} 
          alt={artykul.zdjCieGWne.alt || artykul.tytu}
          class="absolute inset-0 w-full h-full object-cover opacity-90 transition-transform duration-1000 hover:scale-105"
        />
        <div class="absolute inset-0 bg-linear-to-t from-brand-dark/80 via-brand-dark/10 to-transparent"></div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-4 relative z-20 -mt-24 md:-mt-32 reveal delay-100">
      
      <article class="bg-white/80 backdrop-blur-2xl border border-white/60 rounded-[3rem] p-8 md:p-16 shadow-2xl shadow-brand-dark/10 relative overflow-hidden">
        
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-white rounded-full blur-3xl opacity-80 pointer-events-none"></div>

        <div class="relative z-10">
          
          <header class="mb-12 text-center border-b border-gray-200/60 pb-12">
            <span class="inline-block px-4 py-2 bg-brand-signal/10 text-brand-signal text-xs md:text-sm font-bold uppercase tracking-widest rounded-xl mb-6 shadow-sm border border-brand-signal/20">
              Poradnik Eksperta
            </span>
            <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-brand-dark mb-8 leading-tight">
              {artykul.tytu}
            </h1>
            
            <div class="flex items-center justify-center gap-4 mt-8">
              <div class="w-12 h-12 bg-brand-dark rounded-full flex items-center justify-center text-white font-display font-bold text-xl shadow-md">
                W
              </div>
              <div class="text-left">
                <p class="font-bold text-brand-dark leading-none">Wierttrans</p>
                <p class="text-sm text-gray-500 mt-1">Czas czytania: ~{czasCzytania} min</p>
              </div>
            </div>
          </header>

          <p class="text-xl md:text-2xl text-gray-700 font-medium leading-relaxed mb-12 text-center max-w-4xl mx-auto">
            {artykul.zajawka}
          </p>

          <div 
            class="prose prose-lg md:prose-xl max-w-none text-gray-800 leading-relaxed
                   prose-headings:font-display prose-headings:font-bold prose-headings:text-brand-dark 
                   prose-h1:text-4xl prose-h2:text-3xl prose-h3:text-2xl
                   prose-a:text-brand-signal prose-a:no-underline hover:prose-a:underline
                   prose-li:marker:text-brand-signal prose-strong:text-brand-dark prose-strong:font-bold"
            set:html={treHtml}
          ></div>

        </div>
      </article>

    </div>

    <div class="mt-24 text-center reveal">
      <h3 class="text-3xl font-display font-bold text-brand-dark mb-6">Masz pytania po lekturze?</h3>
      <p class="text-lg text-gray-600 mb-8">Nasi specjaliści chętnie rozwieją Twoje wątpliwości. Skonsultuj się z nami za darmo.</p>
      <a href="/kontakt" class="inline-flex items-center px-8 py-4 bg-brand-dark text-white rounded-xl font-bold hover:bg-brand-signal transition-colors duration-300 shadow-xl shadow-brand-dark/20 transform hover:-translate-y-1 group">
        Skontaktuj się z nami
        <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

  </main>
</BaseLayout>