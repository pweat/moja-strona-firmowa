---
// src/pages/kontakt.astro
import BaseLayout from '../layouts/BaseLayout.astro';

// LOGIKA FULLSTACK: Sprawdzamy, czy formularz został przed chwilą wysłany
const isSuccess = Astro.url.searchParams.get('success') === 'true';

// MAGIA SEO: Zaktualizowane FAQ z Twojej starej strony dla Google
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Na jakim obszarze świadczycie usługi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nasze usługi są dostępne na obszarze do 150 km od Kwidzyna, znajdującego się w województwie pomorskim. Nasz zasięg obejmuje takie województwa jak: Pomorskie, Zachodniopomorskie, Kujawsko-Pomorskie, Warmińsko-Mazurskie."
      }
    },
    {
      "@type": "Question",
      "name": "Co to jest studnia głębinowa i jakie są jej zalety?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Studnia głębinowa to specjalistyczny odwiert, który pozwala na uzyskanie dostępu do własnego źródła wody głębinowej. Jest to idealne rozwiązanie dla tych, którzy cenią sobie niezależność i chcą korzystać z własnej wody."
      }
    },
    {
      "@type": "Question",
      "name": "Jak długo trwa proces wiercenia studni głębinowej?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Realizacja studni głębinowej dla budynku jednorodzinnego zajmuje zazwyczaj od 1 do 3 dni, w zależności od specyficznych warunków na miejscu budowy. Podłączenie studni do budynku jest zwykle zakończone w ciągu jednego dnia, co zapewnia szybką i efektywną instalację."
      }
    },
    {
      "@type": "Question",
      "name": "Jaki jest koszt wywiercenia studni głębinowej?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Koszt realizacji studni głębinowej jest ustalany indywidualnie, ponieważ zależy on bezpośrednio od głębokości odwiertu. Zapewniamy naszym klientom szczegółową wycenę, dostosowaną do ich specyficznych potrzeb i wymagań."
      }
    },
    {
      "@type": "Question",
      "name": "Czy dajecie gwarancję wody ze studni?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Jedną z głównych przewag naszej firmy w porównaniu do konkurencji jest unikalna gwarancja uzyskania wody. Rozliczenie za wykonaną pracę następuje dopiero po pomyślnym uzyskaniu wody ze studni. Co więcej, w przypadku odwiertu, który nie dostarcza wody, nie naliczamy opłat. Dzięki temu nasi klienci mogą mieć pewność, że ich inwestycja jest w pełni zabezpieczona."
      }
    },
    {
      "@type": "Question",
      "name": "Czy mogę zainstalować system uzdatniania wody do mojej studni głębinowej?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Z naszym doświadczeniem i wynikami badań wody, jesteśmy w stanie uzdatnić niemal każdą wodę. Kluczowe jest dobór właściwych urządzeń uzdatniających, które są dostosowane do specyficznych wyników badań wody. Dzięki temu zapewniamy skuteczne i bezpieczne rozwiązania, spełniające indywidualne potrzeby każdego klienta."
      }
    }
  ]
};
---

<BaseLayout title="Kontakt i FAQ | Wierttrans - Darmowa Wycena">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="relative overflow-hidden bg-brand-light min-h-screen pb-24">
    
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#8080801a_1px,transparent_1px),linear-gradient(to_bottom,#8080801a_1px,transparent_1px)] bg-[length:24px_24px] pointer-events-none z-0"></div>
    <div class="absolute left-[-10%] top-[10%] z-0 h-[600px] w-[600px] rounded-full bg-brand-signal opacity-[0.06] blur-[120px] mix-blend-multiply pointer-events-none"></div>
    <div class="absolute right-[-5%] top-[50%] z-0 h-[500px] w-[500px] rounded-full bg-blue-500 opacity-[0.05] blur-[150px] mix-blend-multiply pointer-events-none"></div>

    <div class="pt-32 px-4 max-w-7xl mx-auto relative z-10">
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 mb-32">
        
        <div class="reveal">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-200 text-brand-signal font-bold tracking-widest uppercase text-xs md:text-sm mb-6 shadow-sm">
            <span class="w-2 h-2 rounded-full bg-brand-signal animate-pulse"></span>
            Darmowa Wycena
          </span>
          <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold mb-8 tracking-tight text-brand-dark leading-tight">
            Zacznijmy Twój <span class="text-brand-signal">projekt.</span>
          </h1>
          <p class="text-xl text-gray-600 mb-12 max-w-lg leading-relaxed">
            Masz pytania dotyczące studni głębinowej, dolnego źródła pompy ciepła lub uzdatniania wody? Jesteśmy do  Twojej dyspozycji.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            
            <a href="tel:+48000000000" class="group flex flex-col p-6 bg-white/70 backdrop-blur-md border border-white rounded-[2rem] shadow-sm hover:shadow-xl hover:shadow-brand-signal/10 transition-all duration-300">
              <div class="w-12 h-12 bg-brand-light text-brand-signal rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <p class="text-sm text-gray-500 uppercase tracking-wider font-semibold mb-1">Zadzwoń</p>
              <p class="text-xl font-display font-bold text-brand-dark group-hover:text-brand-signal transition-colors">+48 737 445 243</p>
            </a>

            <a href="mailto:biuro@wierttrans.pl" class="group flex flex-col p-6 bg-white/70 backdrop-blur-md border border-white rounded-[2rem] shadow-sm hover:shadow-xl hover:shadow-brand-signal/10 transition-all duration-300">
              <div class="w-12 h-12 bg-brand-light text-brand-signal rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
              </div>
              <p class="text-sm text-gray-500 uppercase tracking-wider font-semibold mb-1">Napisz</p>
              <p class="text-xl font-display font-bold text-brand-dark group-hover:text-brand-signal transition-colors">wierttrans@gmail.com</p>
            </a>

            <div class="sm:col-span-2 flex items-center p-6 bg-white/70 backdrop-blur-md border border-white rounded-[2rem] shadow-sm">
              <div class="w-12 h-12 bg-gray-100 text-gray-600 rounded-xl flex items-center justify-center shrink-0 mr-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <p class="text-sm text-gray-500 uppercase tracking-wider font-semibold mb-1">Obszar działania</p>
                <p class="text-lg font-display font-bold text-brand-dark">Kwidzyn + 150 km</p>
              </div>
            </div>

          </div>
        </div>

        <div class="relative reveal delay-100">
          <div class="absolute -top-10 -right-10 w-40 h-40 bg-brand-signal/20 rounded-full blur-3xl pointer-events-none"></div>
          
          <div class="bg-white/80 backdrop-blur-2xl p-8 md:p-12 rounded-[3rem] shadow-2xl shadow-gray-200/50 border border-white relative z-10">
            
            {isSuccess && (
              <div class="mb-8 p-6 bg-green-50 border border-green-200 rounded-2xl text-green-800 flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <div>
                  <h3 class="font-bold text-lg mb-1">Wiadomość wysłana!</h3>
                  <p class="text-sm opacity-90">Dziękujemy za kontakt. Odpowiemy na Twoje zapytanie najszybciej jak to możliwe.</p>
                </div>
              </div>
            )}

            <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
              
              <input type="hidden" name="access_key" value="1f8d3958-76c6-41eb-b90b-82806464e30c">
              <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
              <input type="hidden" name="redirect" value="http://localhost:4321/kontakt?success=true">

              <div>
                <label for="name" class="block text-sm font-bold text-brand-dark mb-2 ml-1">Imię i nazwisko</label>
                <input type="text" id="name" name="name" required placeholder="Jan Kowalski" class="w-full px-5 py-4 rounded-2xl border border-gray-200 focus:border-brand-signal focus:ring-4 focus:ring-brand-signal/10 outline-none transition-all bg-white/50 focus:bg-white placeholder-gray-400 font-medium">
              </div>

              <div>
                <label for="phone" class="block text-sm font-bold text-brand-dark mb-2 ml-1">Numer telefonu</label>
                <input type="tel" id="phone" name="phone" required placeholder="+48 ___ ___ ___" class="w-full px-5 py-4 rounded-2xl border border-gray-200 focus:border-brand-signal focus:ring-4 focus:ring-brand-signal/10 outline-none transition-all bg-white/50 focus:bg-white placeholder-gray-400 font-medium">
              </div>

              <div>
                <label for="message" class="block text-sm font-bold text-brand-dark mb-2 ml-1">Jak możemy pomóc?</label>
                <textarea id="message" name="message" rows="4" required placeholder="Opisz krótko, czego dotyczy Twój projekt..." class="w-full px-5 py-4 rounded-2xl border border-gray-200 focus:border-brand-signal focus:ring-4 focus:ring-brand-signal/10 outline-none transition-all bg-white/50 focus:bg-white placeholder-gray-400 font-medium resize-none"></textarea>
              </div>

              <button type="submit" class="w-full bg-brand-dark text-white font-bold text-lg py-5 rounded-2xl hover:bg-brand-signal transition-all duration-300 shadow-xl shadow-brand-dark/20 transform hover:-translate-y-1 mt-4 group flex justify-center items-center">
                Wyślij zapytanie
                <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>
            </form>
          </div>
        </div>
      </div>

      <div class="max-w-4xl mx-auto reveal mt-24">
        <div class="text-center mb-12">
          <h2 class="font-display text-4xl md:text-5xl font-bold text-brand-dark mb-4">F.A.Q.</h2>
          <p class="text-xl text-gray-600">Rozwiewamy wszelkie wątpliwości przed wyceną.</p>
        </div>

        <div class="space-y-4">
          {faqSchema.mainEntity.map((faq) => (
            <div class="faq-item bg-white/80 backdrop-blur-sm border border-white rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-lg hover:border-brand-signal/30 shadow-sm">
              <button class="faq-button w-full px-6 py-6 text-left flex justify-between items-center focus:outline-none cursor-pointer group">
                <span class="font-bold text-lg text-brand-dark pr-4 group-hover:text-brand-signal transition-colors">{faq.name}</span>
                <div class="w-10 h-10 rounded-full bg-brand-light flex items-center justify-center shrink-0">
                  <svg class="faq-icon w-5 h-5 text-brand-signal transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
                </div>
              </button>
              <div class="faq-answer grid transition-all duration-300" style="grid-template-rows: 0fr;">
                <div class="overflow-hidden">
                  <p class="px-6 pb-6 pt-2 text-gray-600 leading-relaxed text-lg">
                    {faq.acceptedAnswer.text}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
  // Zabezpieczony skrypt FAQ (odporny na View Transitions)
  const initContactFAQ = () => {
    const faqButtons = document.querySelectorAll('.faq-button');

    faqButtons.forEach(button => {
      if ((button as HTMLElement).dataset.loaded) return;
      (button as HTMLElement).dataset.loaded = 'true';

      button.addEventListener('click', () => {
        const answer = button.nextElementSibling as HTMLElement;
        const icon = button.querySelector('.faq-icon') as HTMLElement;
        const isOpen = answer.style.gridTemplateRows === '1fr';

        document.querySelectorAll('.faq-answer').forEach(el => {
          (el as HTMLElement).style.gridTemplateRows = '0fr';
        });
        document.querySelectorAll('.faq-icon').forEach(el => {
          (el as HTMLElement).style.transform = 'rotate(0deg)';
        });

        if (!isOpen) {
          answer.style.gridTemplateRows = '1fr';
          icon.style.transform = 'rotate(45deg)';
        }
      });
    });
  };

  initContactFAQ();
  document.addEventListener('astro:page-load', initContactFAQ);
</script>