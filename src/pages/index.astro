---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchDatoCMS } from '../lib/datocms';

interface Realizacja {
  tytul: string;
  slug: string;
  zdjCieGWne: {
    url: string;
    alt: string;
  };
}

const query = `
  {
    allRealizacjas {
      tytul
      slug
      zdjCieGWne {
        url
        alt
      }
    }
  }
`;

const data = await fetchDatoCMS(query);
const ostatnieRealizacje: Realizacja[] = data.allRealizacjas.slice(0, 3);
---

<BaseLayout title="Wierttrans | Studnie Głębinowe i Pompy Ciepła">
  <main>
    
    <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden bg-brand-light">
      <div class="max-w-7xl mx-auto px-4 w-full relative z-10">
        <div class="max-w-4xl reveal">
          <span class="text-brand-signal font-bold tracking-widest uppercase text-sm md:text-base mb-6 block">
            Niezależność wodna i energetyczna
          </span>
          <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-brand-dark leading-[1.1] mb-8 tracking-tight">
            Wiercimy z <span class="text-brand-signal relative">
              pasją.
              <svg class="absolute w-full h-3 -bottom-1 left-0 text-brand-signal opacity-30" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="4" fill="transparent"/></svg>
            </span><br />
            Budujemy na lata.
          </h1>
          <p class="text-xl md:text-2xl text-gray-600 mb-12 max-w-2xl leading-relaxed reveal delay-100">
            Kompleksowe odwierty, pompy ciepła i stacje uzdatniania wody dla domów i przemysłu w Kwidzynie i okolicach.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 reveal delay-200">
            <a href="/kontakt" class="px-8 py-4 bg-brand-dark text-white rounded-xl font-bold text-center hover:bg-brand-signal hover:-translate-y-1 transition-all duration-300 shadow-lg shadow-brand-dark/20 text-lg">
              Darmowa Wycena
            </a>
            <a href="/realizacje" class="px-8 py-4 bg-white text-brand-dark border border-gray-200 rounded-xl font-bold text-center hover:border-brand-signal hover:text-brand-signal transition-colors duration-300 text-lg">
              Zobacz nasze prace
            </a>
          </div>
        </div>
      </div>
      
      <div class="absolute right-[-10%] top-[10%] w-[600px] h-[600px] bg-gradient-to-br from-gray-100 to-gray-50 rounded-full blur-3xl -z-10 reveal delay-300"></div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
          
          <a href="/uslugi#studnie" class="reveal block group p-6 -m-6 rounded-3xl hover:bg-gray-50 transition-colors duration-300">
            <div class="w-14 h-14 bg-brand-light rounded-2xl flex items-center justify-center mb-6 text-brand-signal group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
            </div>
            <h3 class="text-2xl font-bold font-display mb-4 text-brand-dark group-hover:text-brand-signal transition-colors">Głębokie Odwierty</h3>
            <p class="text-gray-600 leading-relaxed">Profesjonalny sprzęt wiertniczy pozwalający na dotarcie do najczystszych pokładów wody, niezależnie od trudności terenu.</p>
          </a>

          <a href="/uslugi#pompy" class="reveal delay-100 block group p-6 -m-6 rounded-3xl hover:bg-gray-50 transition-colors duration-300">
            <div class="w-14 h-14 bg-brand-light rounded-2xl flex items-center justify-center mb-6 text-brand-signal group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="text-2xl font-bold font-display mb-4 text-brand-dark group-hover:text-brand-signal transition-colors">Pompy Ciepła</h3>
            <p class="text-gray-600 leading-relaxed">Ekologiczne i darmowe ogrzewanie Twojego domu. Zajmujemy się pełnym montażem i doborem urządzeń najwyższej klasy.</p>
          </a>

          <a href="/uslugi#uzdatnianie" class="reveal delay-200 block group p-6 -m-6 rounded-3xl hover:bg-gray-50 transition-colors duration-300">
            <div class="w-14 h-14 bg-brand-light rounded-2xl flex items-center justify-center mb-6 text-brand-signal group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
            </div>
            <h3 class="text-2xl font-bold font-display mb-4 text-brand-dark group-hover:text-brand-signal transition-colors">Uzdatnianie Wody</h3>
            <p class="text-gray-600 leading-relaxed">Badamy jakość wody i dobieramy systemy filtracji, abyś mógł cieszyć się krystalicznie czystą i zdrową wodą prosto z kranu.</p>
          </a>

        </div>
      </div>
    </section>

    <section class="py-20 bg-brand-dark relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-brand-dark to-gray-900 z-0"></div>
      <svg class="absolute right-0 top-0 h-full w-1/2 text-white opacity-5 transform translate-x-1/3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
      
      <div class="max-w-7xl mx-auto px-4 relative z-10 flex flex-col md:flex-row items-center justify-between gap-10 reveal">
        <div class="max-w-2xl text-center md:text-left">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Nie kupuj kota w worku.</h2>
          <p class="text-gray-300 text-lg leading-relaxed">W branży wiertniczej precyzja to podstawa. Zobacz nasz rygorystyczny, 10-etapowy proces realizacji – od pierwszej analizy aż po testy laboratoryjne wody.</p>
        </div>
        <div class="flex-shrink-0">
          <a href="/proces" class="inline-flex items-center px-8 py-4 bg-brand-signal text-white rounded-xl font-bold hover:bg-white hover:text-brand-dark transition-colors duration-300 shadow-xl shadow-brand-signal/20 transform hover:-translate-y-1 text-lg">
            Zobacz jak pracujemy
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7-7m7-7H3"></path></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="py-24 bg-brand-light">
      <div class="max-w-7xl mx-auto px-4">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 reveal">
          <div class="max-w-2xl">
            <h2 class="font-display text-4xl md:text-5xl font-bold text-brand-dark mb-4">Nasze Ostatnie Prace</h2>
            <p class="text-gray-600 text-lg">Zobacz projekty, które z dumą oddaliśmy naszym klientom w ostatnim czasie.</p>
          </div>
          <a href="/realizacje" class="hidden md:inline-flex items-center text-brand-dark font-bold hover:text-brand-signal transition-colors group">
            Zobacz wszystkie
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7-7m7-7H3"></path></svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {ostatnieRealizacje.map((projekt, index) => (
            <a href={`/realizacje/${projekt.slug}`} class={`group block cursor-pointer reveal delay-${(index + 1) * 100}`}>
              <div class="relative overflow-hidden rounded-2xl mb-6 aspect-[4/3] bg-gray-200">
                <img 
                  src={projekt.zdjCieGWne.url} 
                  alt={projekt.zdjCieGWne.alt || projekt.tytul}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-brand-dark/0 group-hover:bg-brand-dark/10 transition-colors duration-500"></div>
              </div>
              <h3 class="font-display font-bold text-2xl text-brand-dark group-hover:text-brand-signal transition-colors">
                {projekt.tytul}
              </h3>
            </a>
          ))}
        </div>

        <a href="/realizacje" class="md:hidden mt-10 inline-flex items-center text-brand-dark font-bold hover:text-brand-signal transition-colors group reveal">
          Zobacz wszystkie prace
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7-7m7-7H3"></path></svg>
        </a>

      </div>
    </section>

    <section class="py-24 bg-white text-center">
      <div class="max-w-4xl mx-auto px-4 reveal">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-brand-dark mb-8">Gotowy na własne źródło wody?</h2>
        <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
          Skontaktuj się z nami już dziś. Przygotujemy darmową wycenę i odpowiemy na wszystkie Twoje pytania.
        </p>
        <a href="/kontakt" class="inline-block px-10 py-5 bg-brand-dark text-white rounded-xl font-bold text-lg hover:bg-brand-signal transition-colors duration-300 shadow-xl shadow-brand-dark/20 transform hover:-translate-y-1">
          Skontaktuj się z nami
        </a>
      </div>
    </section>

  </main>
</BaseLayout>