---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchDatoCMS } from '../lib/datocms';

interface Realizacja {
  tytul: string;
  slug: string;
  zdjCieGWne: {
    url: string;
    alt: string;
  };
}

const query = `
  {
    allRealizacjas {
      tytul
      slug
      zdjCieGWne {
        url
        alt
      }
    }
  }
`;

const data = await fetchDatoCMS(query);
const ostatnieRealizacje: Realizacja[] = data.allRealizacjas.slice(0, 3);
---

<BaseLayout title="Wierttrans | Studnie Głębinowe i Stacje Uzdatniania">
  <main class="relative overflow-hidden bg-brand-light min-h-screen">
    
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#8080801a_1px,transparent_1px),linear-gradient(to_bottom,#8080801a_1px,transparent_1px)] bg-[length:24px_24px] pointer-events-none z-0"></div>

    <div class="absolute left-[-10%] top-[0%] z-0 h-100 w-100 rounded-full bg-brand-signal opacity-[0.10] blur-[120px] mix-blend-multiply pointer-events-none"></div>
    <div class="absolute right-[5%] top-[10%] z-0 h-125 w-125 rounded-full bg-blue-500 opacity-[0.06] blur-[150px] mix-blend-multiply pointer-events-none"></div>
    <div class="absolute left-[20%] top-[60%] z-0 h-125 w-125 rounded-full bg-brand-signal opacity-[0.05] blur-[150px] mix-blend-multiply pointer-events-none"></div>

    <section class="relative min-h-[90vh] flex items-center pt-20 pb-12 z-10">
      <div class="max-w-7xl mx-auto px-4 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          
          <div class="lg:col-span-7 reveal">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-200 text-brand-signal font-bold tracking-widest uppercase text-xs md:text-sm mb-8 shadow-sm">
              <span class="w-2 h-2 rounded-full bg-brand-signal animate-pulse"></span>
              Niezależność wodna
            </span>
            
            <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-brand-dark leading-[1.1] mb-8 tracking-tight">
              Wiercimy z <span class="text-brand-signal relative inline-block">
                pasją.
                <svg class="absolute w-full h-3 -bottom-2 left-0 text-brand-signal opacity-30" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="4" fill="transparent"/></svg>
              </span><br />
              Budujemy na lata.
            </h1>
            
            <p class="text-xl md:text-2xl text-gray-600 mb-12 max-w-xl leading-relaxed reveal delay-100">
              Kompleksowe odwierty pod studnie i pompy ciepła. Stacje uzdatniania wody dla domów i przemysłu w Kwidzynie i okolicach.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 reveal delay-200">
              <a href="/kontakt" class="px-8 py-4 bg-brand-dark text-white rounded-xl font-bold text-center hover:bg-brand-signal transition-colors duration-300 shadow-xl shadow-brand-dark/20 text-lg flex items-center justify-center gap-2 group">
                Darmowa Wycena
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
              <a href="/realizacje" class="px-8 py-4 bg-white/80 backdrop-blur-sm text-brand-dark border border-gray-200 rounded-xl font-bold text-center hover:border-brand-signal hover:text-brand-signal transition-colors duration-300 text-lg">
                Zobacz nasze prace
              </a>
            </div>
          </div>

          <div class="hidden lg:block lg:col-span-5 relative h-125 reveal delay-300">
            
            <div class="absolute right-0 top-12 bg-white/90 backdrop-blur-xl p-6 rounded-3xl shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] border border-white w-72 animate-float">
              <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                </div>
                <div>
                  <p class="text-sm text-gray-500 font-medium uppercase tracking-wider mb-1">Gwarancja</p>
                  <p class="font-display font-bold text-brand-dark text-xl leading-tight">Uzyskania<br/>Wody</p>
                </div>
              </div>
            </div>

            <div class="absolute left-4 bottom-24 bg-white/90 backdrop-blur-xl p-6 rounded-3xl shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] border border-white w-72 animate-float-delayed">
              <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-brand-signal/10 text-brand-signal rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
                </div>
                <div>
                  <p class="font-display font-bold text-brand-dark text-3xl mb-1">100%</p>
                  <p class="text-sm text-gray-500 font-medium leading-tight">Profesjonalizmu<br/>w każdym calu</p>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <section class="py-24 relative z-10">
      <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
          
          <a href="/uslugi#studnie" class="reveal block group bg-white/80 backdrop-blur-md p-8 rounded-3xl border border-white shadow-lg shadow-gray-200/30 hover:border-brand-signal hover:shadow-brand-signal/10 transition-all duration-300">
            <div class="w-14 h-14 bg-brand-light rounded-2xl flex items-center justify-center mb-6 text-brand-signal group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
            </div>
            <h3 class="text-2xl font-bold font-display mb-4 text-brand-dark group-hover:text-brand-signal transition-colors">Studnie Głębinowe</h3>
            <p class="text-gray-600 leading-relaxed">Nasza firma specjalizuje się w profesjonalnym i kompleksowym wykonywaniu ujęć wody ze studni głębinowych.</p>
          </a>

          <a href="/uslugi#pompy" class="reveal delay-100 block group bg-white/80 backdrop-blur-md p-8 rounded-3xl border border-white shadow-lg shadow-gray-200/30 hover:border-brand-signal hover:shadow-brand-signal/10 transition-all duration-300">
            <div class="w-14 h-14 bg-brand-light rounded-2xl flex items-center justify-center mb-6 text-brand-signal group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="text-2xl font-bold font-display mb-4 text-brand-dark group-hover:text-brand-signal transition-colors">Pompy Ciepła</h3>
            <p class="text-gray-600 leading-relaxed">Nasza firma specjalizuje się w profesjonalnym wykonywaniu odwiertów pod sondy do gruntowych pomp ciepła, które stanowią nowoczesne źródło energii i komfortu.</p>
          </a>

          <a href="/uslugi#uzdatnianie" class="reveal delay-200 block group bg-white/80 backdrop-blur-md p-8 rounded-3xl border border-white shadow-lg shadow-gray-200/30 hover:border-brand-signal hover:shadow-brand-signal/10 transition-all duration-300">
            <div class="w-14 h-14 bg-brand-light rounded-2xl flex items-center justify-center mb-6 text-brand-signal group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
            </div>
            <h3 class="text-2xl font-bold font-display mb-4 text-brand-dark group-hover:text-brand-signal transition-colors">Uzdatnianie Wody</h3>
            <p class="text-gray-600 leading-relaxed">Nasza firma oferuje kompleksowe usługi uzdatniania wody, które pomogą pozbyć się niechcianych pierwiastków z wody studziennej.</p>
          </a>

        </div>
      </div>
    </section>

    <section class="py-20 bg-brand-dark relative overflow-hidden z-10 my-12">
      <div class="absolute inset-0 bg-linear-to-r from-brand-dark to-gray-900 z-0"></div>
      <svg class="absolute right-0 top-0 h-full w-1/2 text-white opacity-5 transform translate-x-1/3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
      
      <div class="max-w-7xl mx-auto px-4 relative z-10 flex flex-col md:flex-row items-center justify-between gap-10 reveal">
        <div class="max-w-2xl text-center md:text-left">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Nie kupuj kota w worku.</h2>
          <p class="text-gray-300 text-lg leading-relaxed">Zobacz sam jak to u nas wygląda.<br/>Sprawdź nasz 10-etapowy proces realizacji – od wizji lokalnej aż po montaż i uruchomienie.</p>
        </div>
        <div class="shrink-0">
          <a href="/proces" class="inline-flex items-center px-8 py-4 bg-brand-signal text-white rounded-xl font-bold hover:bg-white hover:text-brand-dark transition-colors duration-300 shadow-xl shadow-brand-signal/20 transform hover:-translate-y-1 text-lg group">
            Zobacz jak pracujemy
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="py-24 relative z-10">
      <div class="max-w-7xl mx-auto px-4">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 reveal">
          <div class="max-w-2xl">
            <h2 class="font-display text-4xl md:text-5xl font-bold text-brand-dark mb-4">Nasze Ostatnie Prace</h2>
            <p class="text-gray-600 text-lg">Zobacz projekty, które zrealizowaliśmy w ostatnim czasie.</p>
          </div>
          <a href="/realizacje" class="hidden md:inline-flex items-center text-brand-dark font-bold hover:text-brand-signal transition-colors group">
            Zobacz wszystkie
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {ostatnieRealizacje.map((projekt, index) => (
            <a href={`/realizacje/${projekt.slug}`} class={`group block cursor-pointer reveal delay-${(index + 1) * 100}`}>
              <div class="relative overflow-hidden rounded-2xl mb-6 aspect-4/3 bg-gray-200 border border-white shadow-lg shadow-gray-200/50">
                <img 
                  src={`${projekt.zdjCieGWne.url}?auto=format&w=800&q=75`} 
                  alt={projekt.zdjCieGWne.alt || projekt.tytul}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-brand-dark/0 group-hover:bg-brand-dark/10 transition-colors duration-500"></div>
              </div>
              <h3 class="font-display font-bold text-2xl text-brand-dark group-hover:text-brand-signal transition-colors">
                {projekt.tytul}
              </h3>
            </a>
          ))}
        </div>

        <a href="/realizacje" class="md:hidden mt-10 inline-flex items-center text-brand-dark font-bold hover:text-brand-signal transition-colors group reveal">
          Zobacz wszystkie prace
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

      </div>
    </section>

    <section class="py-24 relative z-10 text-center">
      <div class="max-w-4xl mx-auto px-6 py-16 bg-white/70 backdrop-blur-xl border border-white rounded-[3rem] shadow-xl shadow-gray-200/50 reveal">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-brand-dark mb-8">Gotowy na własne źródło wody?</h2>
        <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
          Skontaktuj się z nami już dziś. Przygotujemy darmową wycenę i odpowiemy na wszystkie Twoje pytania.
        </p>
        <a href="/kontakt" class="inline-block px-10 py-5 bg-brand-dark text-white rounded-xl font-bold text-lg hover:bg-brand-signal transition-colors duration-300 shadow-xl shadow-brand-dark/20 transform hover:-translate-y-1">
          Skontaktuj się z nami
        </a>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  .animate-float-delayed {
    animation: float 8s ease-in-out infinite;
    animation-delay: 2s;
  }
</style>