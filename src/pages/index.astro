---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Strona Główna | Premium Minimal">
  <main class="flex flex-col items-center justify-center h-screen px-4 text-center">
    
    <h1 class="font-display text-5xl md:text-7xl font-bold mb-6 tracking-tight">
      Minimalizm & <span class="text-brand-signal">Sygnał</span>
    </h1>
    
    <p class="text-lg md:text-xl max-w-2xl mb-10 opacity-80">
      Testujemy najnowsze środowisko Astro i Tailwind v4. Wszystko działa perfekcyjnie.
    </p>

    <button class="bg-brand-signal text-brand-white px-8 py-4 rounded-full font-medium transition-transform hover:-translate-y-1 hover:shadow-xl cursor-pointer">
      Odkryj możliwości
    </button>
    
  </main>
</BaseLayout>