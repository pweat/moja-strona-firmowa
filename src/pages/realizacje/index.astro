---
// src/pages/realizacje/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchDatoCMS } from '../../lib/datocms';

interface Zdjecie {
  url: string;
  alt?: string;
}

interface Realizacja {
  tytul: string;
  slug: string;
  zdjCieGWne: Zdjecie;
}

interface SzybkaRealizacja {
  id: string;
  podpis: string;
  zdjecie: Zdjecie;
}

// Pobieramy z CMS obie listy naraz!
const query = `
  {
    allRealizacjas(first: 100) {
      tytul
      slug
      zdjCieGWne {
        url
        alt
      }
    }
    allSzybkaRealizacjas(first: 100) {
      id
      podpis
      zdjecie {
        url
        alt
      }
    }
  }
`;

const data = await fetchDatoCMS(query);
const projekty: Realizacja[] = data.allRealizacjas;
const szybkieRealizacje: SzybkaRealizacja[] = data.allSzybkaRealizacjas;

const flagowyProjekt = projekty[0];
const pozostaleProjekty = projekty.slice(1);
---

<BaseLayout title="Nasze Realizacje | Wierttrans - Portfolio">
  <main class="relative overflow-hidden bg-brand-light min-h-screen pb-24">
    
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#8080801a_1px,transparent_1px),linear-gradient(to_bottom,#8080801a_1px,transparent_1px)] bg-[length:24px_24px] pointer-events-none z-0"></div>
    <div class="absolute right-[-10%] top-[5%] z-0 h-100 w-100 rounded-full bg-brand-signal opacity-[0.10] blur-[120px] mix-blend-multiply pointer-events-none"></div>
    <div class="absolute left-[5%] top-[40%] z-0 h-125 w-125 rounded-full bg-blue-500 opacity-[0.06] blur-[150px] mix-blend-multiply pointer-events-none"></div>

    <div class="pt-32 max-w-7xl mx-auto px-4 relative z-10">
      
      <header class="mb-16 md:mb-24 reveal flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="max-w-3xl">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-200 text-brand-dark font-bold tracking-widest uppercase text-xs md:text-sm mb-6 shadow-sm">
            <svg class="w-4 h-4 text-brand-signal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Nasze Portfolio
          </span>
          <h1 class="font-display text-5xl md:text-7xl font-bold text-brand-dark tracking-tight leading-tight">
            Przemówmy <span class="text-brand-signal">czynami.</span>
          </h1>
        </div>
      </header>

      {flagowyProjekt && (
        <a href={`/realizacje/${flagowyProjekt.slug}`} class="block mb-12 reveal group relative overflow-hidden rounded-[3rem] border-2 border-white/60 shadow-2xl shadow-gray-200/50 bg-white/50 backdrop-blur-sm aspect-[4/3] md:aspect-[21/9]">
          <img 
            src={`${flagowyProjekt.zdjCieGWne.url}?auto=format&w=1920&q=80`} 
            alt={flagowyProjekt.zdjCieGWne.alt || flagowyProjekt.tytul}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-linear-to-t from-brand-dark/90 via-brand-dark/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-500"></div>
          
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <span class="inline-block px-3 py-1 bg-brand-signal text-white text-xs font-bold uppercase tracking-wider rounded-lg mb-4">Ostatni duży projekt</span>
            <h2 class="font-display text-3xl md:text-5xl font-bold text-white mb-4">{flagowyProjekt.tytul}</h2>
            <div class="inline-flex items-center text-white font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
              Zobacz szczegóły
              <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      )}

      {pozostaleProjekty.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-32">
          {pozostaleProjekty.map((projekt, index) => (
            <a 
              href={`/realizacje/${projekt.slug}`} 
              class={`group flex flex-col bg-white/90 backdrop-blur-xl border border-white/60 rounded-[3rem] overflow-hidden shadow-2xl shadow-brand-dark/10 transition-all duration-300 hover:scale-105 hover:shadow-brand-signal/20 reveal delay-${(index % 3) * 100}`}
            >
              
              <div class="w-full aspect-[4/3] overflow-hidden shrink-0 border-b border-gray-100">
                <img 
                  src={`${projekt.zdjCieGWne.url}?auto=format&w=800&q=75`} 
                  alt={projekt.zdjCieGWne.alt || projekt.tytul}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
                />
              </div>

              <div class="flex-1 p-8 md:p-10 flex flex-col">
                <h3 class="font-display text-xl md:text-2xl font-bold text-brand-dark leading-tight whitespace-normal mb-6 group-hover:text-brand-signal transition-colors">
                  {projekt.tytul}
                </h3>
                
                <div class="grow"></div>
                
                <div class="inline-flex items-center text-brand-signal font-bold group text-sm md:text-base uppercase tracking-wider">
                  Zobacz szczegóły
                  <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>

            </a>
          ))}
        </div>
      )}

      {szybkieRealizacje.length > 0 && (
        <section class="mt-24 reveal">
          <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6 border-t border-gray-200 pt-16">
            <div>
              <h2 class="font-display text-4xl font-bold text-brand-dark mb-4">Migawki z budowy</h2>
              <p class="text-xl text-gray-600 max-w-2xl">Zlecenia prywatne i codzienna praca naszego zespołu w terenie.</p>
            </div>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
            {szybkieRealizacje.map((snipp, index) => (
              <div 
                class={`quick-gallery-image relative aspect-square rounded-3xl overflow-hidden shadow-md shadow-gray-200/50 border border-white/60 bg-white/50 backdrop-blur-sm group cursor-pointer reveal delay-${(index % 4) * 100}`}
                data-full={`${snipp.zdjecie.url}?auto=format&w=1920&q=85`}
                data-caption={snipp.podpis}
              >
                <img 
                  src={`${snipp.zdjecie.url}?auto=format&w=600&q=75`} 
                  alt={snipp.zdjecie.alt || snipp.podpis} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 pointer-events-none" 
                />
                
                <div class="absolute inset-0 bg-brand-dark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-4 text-center pointer-events-none">
                  <div class="w-12 h-12 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center text-white mb-3">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path></svg>
                  </div>
                  <span class="text-white font-bold text-sm drop-shadow-md translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                    {snipp.podpis}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <section class="mt-32 text-center">
        <div class="max-w-4xl mx-auto px-6 py-16 bg-white/70 backdrop-blur-xl border border-white rounded-[3rem] shadow-xl shadow-gray-200/50 reveal">
          <h2 class="font-display text-4xl md:text-5xl font-bold text-brand-dark mb-8">Twoja działka może być następna.</h2>
          <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
            Masz pytania dotyczące procesu, cen lub możliwości wywiercenia studni na swoim terenie? Jesteśmy do dyspozycji.
          </p>
          <a href="/kontakt" class="inline-block px-10 py-5 bg-brand-dark text-white rounded-xl font-bold text-lg hover:bg-brand-signal transition-colors duration-300 shadow-xl shadow-brand-dark/20 transform hover:-translate-y-1">
            Skonsultuj swój projekt
          </a>
        </div>
      </section>

    </div>
  </main>

  <div id="lightbox" class="fixed inset-0 z-[100] bg-brand-dark/80 backdrop-blur-2xl hidden flex-col items-center justify-center opacity-0 transition-opacity duration-300">
    
    <button id="lightbox-close" class="absolute top-6 right-6 md:top-10 md:right-10 text-white/70 hover:text-brand-signal transition-colors p-2 z-10">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>

    <button id="lightbox-prev" class="absolute left-2 md:left-8 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors p-2 md:p-4 z-10 hidden">
      <svg class="w-10 h-10 md:w-14 md:h-14 drop-shadow-md" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path></svg>
    </button>

    <button id="lightbox-next" class="absolute right-2 md:right-8 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors p-2 md:p-4 z-10 hidden">
      <svg class="w-10 h-10 md:w-14 md:h-14 drop-shadow-md" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
    </button>

    <div class="relative w-full h-[80vh] flex flex-col items-center justify-center p-4 md:p-16 pointer-events-none">
      <img id="lightbox-img" src="" alt="Powiększone zdjęcie" class="max-h-full max-w-full object-contain rounded-2xl shadow-2xl pointer-events-auto transition-opacity duration-200" />
      
      <div id="lightbox-caption" class="mt-6 text-white font-display text-xl md:text-2xl font-bold tracking-wide drop-shadow-lg text-center pointer-events-auto transition-opacity duration-200"></div>
    </div>

  </div>

</BaseLayout>

<script>
  let lightboxKeydownHandler: ((e: KeyboardEvent) => void) | null = null;

  const initLightbox = () => {
    const galleryItems = document.querySelectorAll('.quick-gallery-image');
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxCaption = document.getElementById('lightbox-caption');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');

    if (!lightbox || !lightboxImg || galleryItems.length === 0) return;
    if (lightbox.dataset.loaded === 'true') return;
    lightbox.dataset.loaded = 'true';

    const itemData = Array.from(galleryItems).map(item => ({
      fullUrl: (item as HTMLElement).dataset.full || '',
      caption: (item as HTMLElement).dataset.caption || ''
    }));
    
    let currentIndex = 0;
    let transitionTimeout: number;

    const preloadNextImage = (index: number) => {
      const nextIdx = (index + 1) % itemData.length;
      const preloader = new Image();
      preloader.src = itemData[nextIdx].fullUrl;
    };

    const updateImage = () => {
      lightboxImg.style.opacity = '0';
      if (lightboxCaption) lightboxCaption.style.opacity = '0';
      
      if (transitionTimeout) clearTimeout(transitionTimeout);

      transitionTimeout = window.setTimeout(() => {
        lightboxImg.src = itemData[currentIndex].fullUrl;
        if (lightboxCaption) lightboxCaption.textContent = itemData[currentIndex].caption;
        
        lightboxImg.style.opacity = '1';
        if (lightboxCaption) lightboxCaption.style.opacity = '1';
        
        preloadNextImage(currentIndex);
      }, 200);
    };

    const nextImage = (e?: Event) => {
      if (e) e.stopPropagation();
      currentIndex = (currentIndex + 1) % itemData.length;
      updateImage();
    };

    const prevImage = (e?: Event) => {
      if (e) e.stopPropagation();
      currentIndex = (currentIndex - 1 + itemData.length) % itemData.length;
      updateImage();
    };

    const closeLightbox = () => {
      lightbox.classList.add('opacity-0');
      setTimeout(() => {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
        lightboxImg.src = '';
        if (lightboxCaption) lightboxCaption.textContent = '';
        document.body.style.overflow = '';
      }, 300);
    };

    galleryItems.forEach((item, index) => {
      item.addEventListener('click', () => {
        currentIndex = index;
        lightboxImg.src = itemData[currentIndex].fullUrl;
        if (lightboxCaption) lightboxCaption.textContent = itemData[currentIndex].caption;
        
        lightboxImg.style.opacity = '1';
        if (lightboxCaption) lightboxCaption.style.opacity = '1';
        
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        
        if (itemData.length > 1) {
          prevBtn?.classList.remove('hidden');
          nextBtn?.classList.remove('hidden');
        }

        setTimeout(() => {
          lightbox.classList.remove('opacity-0');
        }, 10);
        
        document.body.style.overflow = 'hidden';
        preloadNextImage(currentIndex);
      });
    });

    closeBtn?.addEventListener('click', closeLightbox);
    nextBtn?.addEventListener('click', nextImage);
    prevBtn?.addEventListener('click', prevImage);

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || (e.target as HTMLElement).classList.contains('pointer-events-none')) {
        closeLightbox();
      }
    });

    if (lightboxKeydownHandler) {
      document.removeEventListener('keydown', lightboxKeydownHandler);
    }

    lightboxKeydownHandler = (e: KeyboardEvent) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight' && itemData.length > 1) nextImage();
      if (e.key === 'ArrowLeft' && itemData.length > 1) prevImage();
    };

    document.addEventListener('keydown', lightboxKeydownHandler);
  };

  document.addEventListener('astro:page-load', initLightbox);
</script>