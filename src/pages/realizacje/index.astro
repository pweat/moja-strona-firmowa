---
// src/pages/realizacje/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchDatoCMS } from '../../lib/datocms';

interface Realizacja {
  tytul: string;
  slug: string;
  zdjCieGWne: {
    url: string;
    alt: string;
  };
}

const query = `
  {
    allRealizacjas(first: 100) {
      tytul
      slug
      zdjCieGWne {
        url
        alt
      }
    }
  }
`;

const data = await fetchDatoCMS(query);
const projekty: Realizacja[] = data.allRealizacjas;

// Wyciągamy pierwszy projekt jako FLAGOWY, reszta ląduje w siatce
const flagowyProjekt = projekty[0];
const pozostaleProjekty = projekty.slice(1);
---

<BaseLayout title="Nasze Realizacje | Wierttrans - Portfolio">
  <main class="relative overflow-hidden bg-brand-light min-h-screen pb-24">
    
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#8080801a_1px,transparent_1px),linear-gradient(to_bottom,#8080801a_1px,transparent_1px)] bg-[length:24px_24px] pointer-events-none z-0"></div>

    <div class="absolute right-[-10%] top-[5%] z-0 h-100 w-100 rounded-full bg-brand-signal opacity-[0.10] blur-[120px] mix-blend-multiply pointer-events-none"></div>
    <div class="absolute left-[5%] top-[40%] z-0 h-125 w-125 rounded-full bg-blue-500 opacity-[0.06] blur-[150px] mix-blend-multiply pointer-events-none"></div>

    <div class="pt-32 max-w-7xl mx-auto px-4 relative z-10">
      
      <header class="mb-16 md:mb-24 reveal flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="max-w-3xl">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-200 text-brand-dark font-bold tracking-widest uppercase text-xs md:text-sm mb-6 shadow-sm">
            <svg class="w-4 h-4 text-brand-signal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Nasze Portfolio
          </span>
          <h1 class="font-display text-5xl md:text-7xl font-bold text-brand-dark tracking-tight leading-tight">
            Przemówmy <span class="text-brand-signal">czynami.</span>
          </h1>
        </div>
        
      </header>

      {flagowyProjekt && (
        <a href={`/realizacje/${flagowyProjekt.slug}`} class="block mb-12 reveal group relative overflow-hidden rounded-[3rem] border-2 border-white/60 shadow-2xl shadow-gray-200/50 bg-white/50 backdrop-blur-sm aspect-[4/3] md:aspect-[21/9]">
          <img 
            src={flagowyProjekt.zdjCieGWne.url} 
            alt={flagowyProjekt.zdjCieGWne.alt || flagowyProjekt.tytul}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-linear-to-t from-brand-dark/90 via-brand-dark/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-500"></div>
          
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <span class="inline-block px-3 py-1 bg-brand-signal text-white text-xs font-bold uppercase tracking-wider rounded-lg mb-4">Ostatnia realizacja</span>
            <h2 class="font-display text-3xl md:text-5xl font-bold text-white mb-4">{flagowyProjekt.tytul}</h2>
            <div class="inline-flex items-center text-white font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
              Zobacz szczegóły projektu
              <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      )}

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {pozostaleProjekty.map((projekt, index) => (
          <a href={`/realizacje/${projekt.slug}`} class={`group block relative overflow-hidden rounded-[2.5rem] border border-white/60 shadow-xl shadow-gray-200/30 bg-white/50 backdrop-blur-sm aspect-4/3 reveal delay-${(index % 3) * 100}`}>
            <img 
              src={projekt.zdjCieGWne.url} 
              alt={projekt.zdjCieGWne.alt || projekt.tytul}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-linear-to-t from-brand-dark/95 via-brand-dark/20 to-transparent opacity-70 group-hover:opacity-90 transition-opacity duration-500"></div>
            
            <div class="absolute bottom-0 left-0 right-0 p-8 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
              <h3 class="font-display font-bold text-2xl text-white mb-2">{projekt.tytul}</h3>
              <div class="inline-flex items-center text-brand-signal font-bold text-sm uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
                Otwórz galerię
                <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <section class="mt-32 text-center">
        <div class="max-w-4xl mx-auto px-6 py-16 bg-white/70 backdrop-blur-xl border border-white rounded-[3rem] shadow-xl shadow-gray-200/50 reveal">
          <h2 class="font-display text-4xl md:text-5xl font-bold text-brand-dark mb-8">Twoja działka może być następna.</h2>
          <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
            Masz pytania dotyczące procesu, cen lub możliwości wywiercenia studni na swoim terenie? Jesteśmy do dyspozycji.
          </p>
          <a href="/kontakt" class="inline-block px-10 py-5 bg-brand-dark text-white rounded-xl font-bold text-lg hover:bg-brand-signal transition-colors duration-300 shadow-xl shadow-brand-dark/20 transform hover:-translate-y-1">
            Skonsultuj swój projekt
          </a>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>